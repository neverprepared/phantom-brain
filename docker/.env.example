# Copy to .env and fill in real values. Used by docker-compose.yml.

# MinIO root credentials. Used to spin up MinIO + mint a
# service-account-like access key the daemon uses internally.
# In single-host dev this is fine; in multi-host prod you'd
# create a scoped service account rather than reusing root.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace_me_with_a_strong_password

# Bucket the daemon uses for death-payload transit. Auto-created
# by the mc-init container on first `docker compose up`.
PB_BUCKET=phantom-brain

# What hostname presigned upload URLs use. Defaults to
# http://localhost:9000 which works for a single-host dev setup.
# Change to http://<server-ip-or-dns>:9000 (or https with a
# reverse proxy) for multi-host or remote-agent setups.
MINIO_PUBLIC_URL=http://localhost:9000
