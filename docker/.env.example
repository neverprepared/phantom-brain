# Copy to .env and fill in real values. Used by docker-compose.yml.

# MinIO root credentials. Used to spin up MinIO + mint a
# service-account-like access key the daemon uses internally.
# In single-host dev this is fine; in multi-host prod you'd
# create a scoped service account rather than reusing root.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace_me_with_a_strong_password

# Bucket the daemon uses for death-payload transit. Auto-created
# by the mc-init container on first `docker compose up`.
PB_BUCKET=phantom-brain

# Postgres — System of Record for the OpenSearch-native redesign
# (epic #92). The pgvector image is used so embedding-similarity is
# available at the SoR. Not yet consumed by the daemon; provisioned
# bottom-up ahead of the schema/projection work.
POSTGRES_USER=pbrain
POSTGRES_PASSWORD=replace_me_with_a_strong_password
POSTGRES_DB=phantom_brain

# What hostname presigned upload URLs use. Defaults to
# http://localhost:9000 which works for a single-host dev setup.
# Change to http://<server-ip-or-dns>:9000 (or https with a
# reverse proxy) for multi-host or remote-agent setups.
MINIO_PUBLIC_URL=http://localhost:9000

# Long-lived Claude Code OAuth token. The daemon's SynthWorker uses
# the bundled `claude` CLI for gate + distill on every synthesised
# doc; without a token the CLI is on PATH but unauthenticated, so
# gate/distill are skipped and the summary body is a verbatim copy
# of the raw content (reliability="medium", topic="general" for
# all docs).
#
# Generate locally with:
#   claude setup-token
# (interactive — opens browser, you authenticate, prints a token).
# Token is tied to your Claude account and uses the same Max-
# subscription quota as your local Claude Code; no separate API
# billing line.
CLAUDE_CODE_OAUTH_TOKEN=
