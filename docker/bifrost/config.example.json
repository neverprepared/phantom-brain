{
  "$schema": "https://www.getbifrost.ai/schema",
  "providers": {
    "ollama": {
      "keys": [
        {
          "name": "ollama-key",
          "value": "dummy",
          "models": ["*"],
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "http://host.docker.internal:11434"
      }
    }
  },
  "config_store": {
    "enabled": true,
    "type": "sqlite",
    "config": { "path": "./config.db" }
  }
}
