# Bifrost satellite stack — copy to .env and fill in.
# All values have working defaults except the provider keys, which are
# only needed if your config.json references them as env.<NAME>.

# Image tag. Pin to a release (e.g. v1.3.9) for reproducible deploys.
BIFROST_VERSION=latest

# Host port to publish the gateway on (container always listens on 8080).
APP_PORT=8080

# debug | info | warn | error
LOG_LEVEL=info
# pretty | json
LOG_STYLE=json

# Provider API keys — referenced from config.json via `env.OPENAI_API_KEY`.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
